# ChangeTrace v2 环境变量配置

# ---- 数据存储 ----
CT_DATA_DIR=/app/data

# ---- 认证 ----
CT_AUTH_ENABLED=false
CT_AUTH_USERNAME=admin
CT_AUTH_PASSWORD=admin
CT_AUTH_SECRET_KEY=your-secret-key-change-me

# ---- 通知：邮件(SMTP) ----
CT_SMTP_HOST=
CT_SMTP_PORT=587
CT_SMTP_USER=
CT_SMTP_PASSWORD=
CT_SMTP_FROM=
CT_SMTP_USE_TLS=true

# ---- 通知：Telegram ----
CT_TELEGRAM_BOT_TOKEN=

# ---- 通知：钉钉 ----
CT_DINGTALK_WEBHOOK_URL=
CT_DINGTALK_SECRET=

# ---- 通知：Slack ----
CT_SLACK_WEBHOOK_URL=

# ---- 运行参数 ----
CT_LOG_LEVEL=INFO
CT_MAX_CONCURRENT_TASKS=5
CT_NOTIFICATION_RETRY_MAX=5
CT_NOTIFICATION_RATE_LIMIT_PER_MINUTE=30
CT_PORT=8000
